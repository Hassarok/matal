# ─────────────────────────────────────────────────────────────
# MATAL — Environment configuration
# Copy this file to `.env` (in the repo root) and fill in values.
# Both the API (NestJS) and the web app (Vite) read from this file.
# Only variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development

# ── API server ───────────────────────────────────────────────
API_PORT=3000
API_GLOBAL_PREFIX=api
# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:5173

# ── Database (PostgreSQL) ────────────────────────────────────
# Matches the credentials in docker-compose.yml by default.
POSTGRES_USER=matal
POSTGRES_PASSWORD=matal_dev_password
POSTGRES_DB=matal
POSTGRES_PORT=5432
DATABASE_URL=postgresql://matal:matal_dev_password@localhost:5432/matal?schema=public

# ── Redis (optional) ─────────────────────────────────────────
# Only used if present; the app runs without it in development.
REDIS_URL=redis://localhost:6379

# ── Web app (exposed to the browser — must be VITE_ prefixed) ─
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=MATAL
