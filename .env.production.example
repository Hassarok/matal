# ─────────────────────────────────────────────────────────────
# MATAL — PRODUCTION environment template
# Copy to `.env` next to docker-compose.prod.yml and fill in real values.
#   cp .env.production.example .env
# Generate secrets with:  openssl rand -base64 48
# ─────────────────────────────────────────────────────────────

NODE_ENV=production

# ── API server ───────────────────────────────────────────────
API_PORT=3000
API_GLOBAL_PREFIX=api
# Public origin(s) that may call the API. With the bundled web container
# (same-origin proxy) this is your public web URL. Comma-separated.
CORS_ORIGINS=https://quiz.example.com
# Public URL of the web app — used to build email verification/reset links.
WEB_APP_URL=https://quiz.example.com

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_USER=matal
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=matal
# Host is the compose service name `postgres` inside the Docker network.
DATABASE_URL=postgresql://matal:CHANGE_ME_strong_db_password@postgres:5432/matal?schema=public

# ── Redis (optional) ─────────────────────────────────────────
# REDIS_URL=redis://redis:6379

# ── Auth / JWT — MUST be strong random values (app refuses dev-* in prod) ──
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_long_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_long_random_secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
VERIFICATION_TOKEN_TTL_SECONDS=86400
RESET_TOKEN_TTL_SECONDS=3600

# ── Cookies ──────────────────────────────────────────────────
# true when served over HTTPS (required for SameSite cookies in prod).
COOKIE_SECURE=true
# COOKIE_DOMAIN=.example.com

# ── Email ────────────────────────────────────────────────────
EMAIL_FROM="MATAL <no-reply@example.com>"

# ── Web container ────────────────────────────────────────────
# Public port the web (nginx) listens on; front this with TLS in production.
WEB_PORT=8080
# Leave empty for the bundled same-origin proxy. Set to the API's public
# origin only if you serve the API from a different host.
VITE_API_URL=
